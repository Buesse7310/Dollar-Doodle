#####
# This is an example .env file containing placeholder/example
# values for the environment variables used in this program.
#
# Create a copy of this file named .env to store the real
# values to be used in the program.
#####

# server port
PORT=5000

# JWT secret key
JWT_SECRET=123456

# Google
GOOGLE_CLIENT_ID=1234567890-abc123def456.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=123456 # currently unnecessary

# Veryfi
VERYFI_CLIENT_ID=
VERYFI_CLIENT_SECRET= # unused
VERYFI_USERNAME=
VERYFI_API_KEY=

# database configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=Dollar_Doodle



